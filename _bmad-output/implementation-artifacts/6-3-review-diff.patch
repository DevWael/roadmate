+package com.roadmate.headunit.ui.parked
+
+import com.roadmate.core.database.entity.MaintenanceSchedule
+import com.roadmate.core.database.entity.OdometerUnit
+import com.roadmate.core.database.entity.Vehicle
+import com.roadmate.core.model.DrivingState
+import org.junit.jupiter.api.Assertions.assertEquals
+import org.junit.jupiter.api.Assertions.assertFalse
+import org.junit.jupiter.api.Assertions.assertTrue
+import org.junit.jupiter.api.DisplayName
+import org.junit.jupiter.api.Nested
+import org.junit.jupiter.api.Test
+
+@DisplayName("DpadFocus")
+class DpadFocusTest {
+
+    @Nested
+    @DisplayName("driving state focus gating")
+    inner class DrivingStateFocusGating {
+
+        @Test
+        @DisplayName("focus enabled when Idle")
+        fun focusEnabledWhenIdle() {
+            val state = DrivingState.Idle
+            assertTrue(state is DrivingState.Idle)
+        }
+
+        @Test
+        @DisplayName("focus disabled when Driving")
+        fun focusDisabledWhenDriving() {
+            val state: DrivingState = DrivingState.Driving("trip1", 10.0, 60000L)
+            assertFalse(state is DrivingState.Idle)
+        }
+
+        @Test
+        @DisplayName("focus disabled when Stopping")
+        fun focusDisabledWhenStopping() {
+            val state: DrivingState = DrivingState.Stopping(1000L)
+            assertFalse(state is DrivingState.Idle)
+        }
+
+        @Test
+        @DisplayName("focus disabled when GapCheck")
+        fun focusDisabledWhenGapCheck() {
+            val state: DrivingState = DrivingState.GapCheck(5000L)
+            assertFalse(state is DrivingState.Idle)
+        }
+    }
+
+    @Nested
+    @DisplayName("maintenance percentage for gauge focus")
+    inner class GaugeFocusData {
+
+        @Test
+        @DisplayName("percentage matches gauge arc display value")
+        fun percentageMatchesDisplay() {
+            val schedule = buildSchedule(intervalKm = 10000, lastServiceKm = 0.0)
+            val percentage = maintenancePercentage(schedule, 7500.0)
+            assertEquals(75f, percentage)
+        }
+
+        @Test
+        @DisplayName("critical threshold triggers different gauge color")
+        fun criticalThreshold() {
+            val schedule = buildSchedule(intervalKm = 10000, lastServiceKm = 0.0)
+            val percentage = maintenancePercentage(schedule, 9600.0)
+            assertTrue(percentage >= 95f)
+        }
+    }
+
+    private fun buildSchedule(
+        name: String = "Test",
+        intervalKm: Int? = 10000,
+        lastServiceKm: Double = 0.0,
+    ) = MaintenanceSchedule(
+        vehicleId = "v1",
+        name = name,
+        intervalKm = intervalKm,
+        lastServiceKm = lastServiceKm,
+        lastServiceDate = 0L,
+        isCustom = false,
+    )
+}
